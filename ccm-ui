#!/bin/bash
############################################################
# CCM Dashboard UI Launcher
# ---------------------------------------------------------
# Launch the web-based CCM Dashboard
############################################################

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Dashboard directory
DASHBOARD_DIR="$HOME/ccm-dashboard"

# Check if dashboard exists
if [[ ! -d "$DASHBOARD_DIR" ]]; then
    echo -e "${YELLOW}⚠️  CCM Dashboard not found at $DASHBOARD_DIR${NC}"
    echo -e "${BLUE}ℹ️  Please install the dashboard first.${NC}"
    exit 1
fi

# Check if Node.js is installed
if ! command -v node &> /dev/null; then
    echo -e "${YELLOW}⚠️  Node.js is not installed${NC}"
    echo -e "${BLUE}ℹ️  Please install Node.js to use the CCM Dashboard.${NC}"
    exit 1
fi

# Navigate to dashboard directory
cd "$DASHBOARD_DIR" || exit 1

# Check if dependencies are installed
if [[ ! -d "node_modules" ]]; then
    echo -e "${BLUE}📦 Installing dependencies...${NC}"
    pnpm install || npm install
fi

# Launch the dashboard
echo -e "${GREEN}🚀 Launching CCM Dashboard...${NC}"
echo -e "${BLUE}ℹ️  Dashboard will open in your browser${NC}"
echo -e "${BLUE}ℹ️  Press Ctrl+C to stop the server${NC}"
echo ""

# Start the dev server
pnpm dev || npm run dev
