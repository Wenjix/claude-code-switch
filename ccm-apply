#!/bin/bash
############################################################
# CCM Apply - Apply pending model switch
# ---------------------------------------------------------
# Reads the switch state file and applies environment vars
############################################################

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# State file location
STATE_FILE="$HOME/.ccm_active_model"

# Check if state file exists
if [[ ! -f "$STATE_FILE" ]]; then
    echo -e "${YELLOW}⚠️  No pending model switch found${NC}"
    echo -e "${BLUE}ℹ️  Use the CCM Dashboard to prepare a model switch${NC}"
    exit 1
fi

# Read and parse JSON state file
if ! command -v jq &> /dev/null; then
    echo -e "${RED}✗ jq is not installed${NC}"
    echo -e "${YELLOW}  Please install jq to use this feature${NC}"
    echo -e "${BLUE}  macOS: brew install jq${NC}"
    echo -e "${BLUE}  Ubuntu/Debian: sudo apt-get install jq${NC}"
    exit 1
fi

# Parse state file
PROVIDER=$(jq -r '.provider' "$STATE_FILE")
PROVIDER_NAME=$(jq -r '.providerName' "$STATE_FILE")
TIMESTAMP=$(jq -r '.timestamp' "$STATE_FILE")

echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║      Applying Model Switch             ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}Provider:${NC} $PROVIDER_NAME"
echo -e "${YELLOW}Prepared:${NC} $(date -r $((TIMESTAMP / 1000)) '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'Unknown')"
echo ""

# Clean existing CCM environment variables
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_API_URL
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_API_KEY
unset ANTHROPIC_MODEL
unset ANTHROPIC_SMALL_FAST_MODEL

# Extract and export configuration
export ANTHROPIC_AUTH_TOKEN=$(jq -r '.config.ANTHROPIC_AUTH_TOKEN' "$STATE_FILE")
export ANTHROPIC_API_KEY=$(jq -r '.config.ANTHROPIC_API_KEY' "$STATE_FILE")
export ANTHROPIC_MODEL=$(jq -r '.config.ANTHROPIC_MODEL' "$STATE_FILE")
export ANTHROPIC_SMALL_FAST_MODEL=$(jq -r '.config.ANTHROPIC_SMALL_FAST_MODEL' "$STATE_FILE")

# Optional fields (only export if present)
BASE_URL=$(jq -r '.config.ANTHROPIC_BASE_URL' "$STATE_FILE")
if [[ "$BASE_URL" != "null" && -n "$BASE_URL" ]]; then
    export ANTHROPIC_BASE_URL="$BASE_URL"
    export ANTHROPIC_API_URL="$BASE_URL"
fi

echo -e "${GREEN}✅ Switched to $PROVIDER_NAME${NC}"
echo ""
echo -e "${BLUE}Configuration:${NC}"
echo -e "   MODEL: $ANTHROPIC_MODEL"
echo -e "   SMALL_MODEL: $ANTHROPIC_SMALL_FAST_MODEL"
if [[ -n "$ANTHROPIC_BASE_URL" ]]; then
    echo -e "   BASE_URL: $ANTHROPIC_BASE_URL"
fi
echo ""
echo -e "${YELLOW}⚠️  Important:${NC}"
echo -e "   1. These environment variables are set for the current shell session"
echo -e "   2. Restart Claude Code for changes to take effect"
echo -e "   3. To make permanent, add to your shell RC file (~/.bashrc or ~/.zshrc)"
echo ""

# Clean up state file
rm -f "$STATE_FILE"
echo -e "${GREEN}✓ Switch state cleared${NC}"
